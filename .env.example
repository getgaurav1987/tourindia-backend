# TBO Corporate Travel Backend — required environment variables
# Copy this file to `.env` for local dev, and set the same keys in the
# Render dashboard (Environment) for the deployed service.
# Do NOT commit the real .env file — it is gitignored.

# TBO booking API credentials
TBO_USERNAME=
TBO_PASSWORD=

# Google Gemini API key (passport OCR)
GEMINI_API_KEY=

# Razorpay payment keys (use rzp_live_... in production)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Fixie HTTP proxy — routes ONLY TBO outbound calls through a fixed, whitelisted IP.
# Format: http://fixie:PASSWORD@ventoux.usefixie.com:80 (get the real value from the Fixie dashboard)
# If unset, TBO calls go direct (no fixed outbound IP).
FIXIE_URL=http://fixie:YOUR_FIXIE_PASSWORD@ventoux.usefixie.com:80

# PORT is injected automatically by Render; only set locally if needed.
# PORT=3001
